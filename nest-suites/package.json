  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@suites/di.nestjs": "3.1.0",
    "@suites/doubles.vitest": "3.1.0",
    "@suites/unit": "3.1.0",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
